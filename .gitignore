# Android signing keys — never commit these
*.keystore
*.jks
*.p12

# iOS secrets — the Sentry DSN lives ONLY in Secrets.xcconfig (gitignored), which
# Config.xcconfig includes and Info.plist exposes as SentryDSN. There is deliberately no
# Secrets.swift: a gitignored *source* file made a fresh clone unbuildable.
iosApp/Configuration/Secrets.xcconfig

*.iml
.kotlin
.gradle
**/build/
xcuserdata
!src/**/build/
local.properties
.idea
.DS_Store
captures
.externalNativeBuild
.cxx
*.xcodeproj/*
!*.xcodeproj/project.pbxproj
!*.xcodeproj/xcshareddata/
!*.xcodeproj/project.xcworkspace/
!*.xcworkspace/contents.xcworkspacedata
**/xcshareddata/WorkspaceSettings.xcsettings
