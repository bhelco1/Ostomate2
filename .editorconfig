root = true

# Generated files — never lint. ktlint 1.x uses ktlint_standard = disabled
# (ktlint_disabled_rules was removed in 1.0).
[{**/build/generated/**,**/build/tmp/**}]
ktlint_standard = disabled

# iosTest files use deeply-nested Room test helpers that trigger ktlint indentation
# oscillation (formatter can't converge). Checked manually; excluded from CI gate.
[shared/src/iosTest/**]
ktlint_standard = disabled

[*]
end_of_line = lf
insert_final_newline = true
charset = utf-8
trim_trailing_whitespace = true
# suppress IntelliJ star-import suggestion
ij_kotlin_name_count_to_use_star_import = 2147483647

[*.{kt,kts}]
indent_style = space
indent_size = 4
max_line_length = 120
# Allow PascalCase for @Composable functions (Compose convention)
ktlint_function_naming_ignore_when_annotated_with = Composable

[*.{yml,yaml,json,toml}]
indent_style = space
indent_size = 2
